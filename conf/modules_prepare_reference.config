/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    oncohawk prepare_reference module configuration
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {

    // PREPARE_REFERENCE outputs go to the reference directory.
    // DOWNLOAD_GENOME is optional when params.genome_fasta is set, so use one
    // selector that matches either process to avoid unmatched-selector warnings.
    withName: 'PREPARE_REFERENCE:(DOWNLOAD_GENOME|INDEX_GENOME)' {
        publishDir = [
            path: { "${params.reference_dir}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

}
