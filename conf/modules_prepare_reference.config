/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    oncohawk prepare_reference module configuration
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {

    withName: 'PREPARE_REFERENCE:DOWNLOAD_GENOME' {
        publishDir = [
            path: { "${params.reference_dir}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // BWAMEM2_INDEX outputs a directory named "bwamem2/" containing all index files.
    // After this runs, set params.ref_data_genome_bwamem2_index = "<reference_dir>/bwamem2".
    withName: 'PREPARE_REFERENCE:BWAMEM2_INDEX' {
        publishDir = [
            path: { "${params.reference_dir}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename }
        ]
    }

}
