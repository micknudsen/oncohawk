/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    oncohawk modules configuration
    Per-process publishDir settings and resource overrides
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {

    // ── PREPARE_REFERENCE outputs go to the reference directory ────────────
    withName: 'PREPARE_REFERENCE:WGET_GENOME' {
        publishDir = [
            path: { "${params.reference_dir}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'PREPARE_REFERENCE:BWAMEM2_INDEX' {
        publishDir = [
            path: { "${params.reference_dir}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // ── ONCOHAWK outputs go to the results directory ────────────────────────

    withName: 'ONCOHAWK:CUTADAPT' {
        publishDir = [
            path: { "${params.outdir}/qc/cutadapt" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                if (filename.equals('versions.yml')) return null
                if (filename.endsWith('.cutadapt.log')) return filename
                return null
            }
        ]
    }

    withName: 'ONCOHAWK:MARKDUP_LIBRARY' {
        publishDir = [
            path: { "${params.outdir}/qc/markdup" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                if (filename.equals('versions.yml')) return null
                if (filename.endsWith('.markdup.json')) return filename
                return null
            }
        ]
    }

    withName: 'ONCOHAWK:MERGE_SAMPLE_LIBRARIES' {
        publishDir = [
            path: { "${params.outdir}/alignment" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

}


