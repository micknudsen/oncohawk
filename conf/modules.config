/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    oncohawk module configuration
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {

    withName: 'ONCOHAWK:CUTADAPT' {
        ext.args = { "-a ${params.adapter_r1} -A ${params.adapter_r2} --minimum-length 35" }
        publishDir = [
            path: { "${params.outdir}/qc/cutadapt" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                if (filename.endsWith('.cutadapt.log')) return filename
                return null
            }
        ]
    }

    withName: 'ONCOHAWK:BWAMEM2_MEM' {
        // Inject per-lane @RG tag; -K 100000000 -Y follow BWA-MEM2 best practices.
        ext.args  = { "-R '${meta.read_group}' -K 100000000 -Y" }
        // samtools sort output flags passed as args2 (sort_bam = true in workflow).
        ext.args2 = '-O BAM'
    }

    withName: 'ONCOHAWK:SAMTOOLS_MERGE' {
        publishDir = [
            path: { "${params.outdir}/alignment" },
            mode: params.publish_dir_mode,
            saveAs: { _filename -> null }
        ]
    }

    withName: 'ONCOHAWK:PICARD_MARKDUPLICATES' {
        // Use distinct prefix to avoid Picard input==output name collision check.
        ext.prefix = { "${meta.id}.markdup" }
        ext.args   = '--CREATE_INDEX true --VALIDATION_STRINGENCY SILENT'
        publishDir = [
            path: { "${params.outdir}" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                if (filename.endsWith('.metrics.txt')) return "qc/picard/${filename}"
                if (filename.endsWith('.bam') || filename.endsWith('.bai')) {
                    def final_name = filename.replace('.markdup', '')
                    return "alignment/${final_name}"
                }
                return null
            }
        ]
    }

    withName: 'PREPARE_REFERENCE:WGET_GENOME_FASTA' {
        publishDir = [
            path: { "${params.reference_dir}" },
            mode: params.publish_dir_mode,
            saveAs: { _filename -> null }
        ]
    }

    withName: 'PREPARE_REFERENCE:WGET_GENCODE_GTF' {
        publishDir = [
            path: { "${params.reference_dir}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename }
        ]
    }

    withName: 'PREPARE_REFERENCE:GUNZIP_GENOME_FASTA' {
        publishDir = [
            path: { "${params.reference_dir}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // BWAMEM2_INDEX outputs directory named "bwamem2/" with all index files.
    // After this runs, set params.ref_data_genome_bwamem2_index = "<reference_dir>/bwamem2".
    withName: 'PREPARE_REFERENCE:BWAMEM2_INDEX' {
        publishDir = [
            path: { "${params.reference_dir}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename }
        ]
    }

}
