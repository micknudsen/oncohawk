/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    oncohawk test profile configuration
    Use this profile for local development on a Mac mini (10 cores, 16 GB RAM).
    Points to small test FASTQ files for fast iteration.
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {

    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal test dataset for local development'

    // Limit resources for local Mac dev
    max_cpus   = 4
    max_memory = '8.GB'
    max_time   = '2.h'

    // Input
    input      = "${projectDir}/test/samplesheet.csv"

    // Reference data — pre-built by running:
    //   nextflow run main.nf --workflow prepare_reference -profile test,docker
    // The test profile points at the small chr22 subset FASTA and its index.
    // BWAMEM2_INDEX publishes a "bwamem2/" directory; point the index param there.
    ref_data_genome_fasta         = "${projectDir}/test/data/reference/chr22_subset.fa"
    ref_data_genome_bwamem2_index = "${projectDir}/test/data/reference/bwamem2"

    // PREPARE_REFERENCE: use the test FASTA directly (no download needed),
    // and publish the index into the same directory as the FASTA so that
    // ref_data_genome_bwamem2_index can point there.
    genome_fasta  = "${projectDir}/test/data/reference/chr22_subset.fa"
    reference_dir = "${projectDir}/test/data/reference"



}

// Override resource labels to stay within local limits
process {
    withLabel: process_single {
        cpus   = 1
        memory = '1.GB'
        time   = '30.m'
    }
    withLabel: process_low {
        cpus   = 2
        memory = '2.GB'
        time   = '30.m'
    }
    withLabel: process_medium {
        cpus   = 4
        memory = '4.GB'
        time   = '1.h'
    }
    withLabel: process_high {
        cpus   = 4
        memory = '8.GB'
        time   = '2.h'
    }
    withLabel: process_long {
        cpus   = 2
        memory = '4.GB'
        time   = '2.h'
    }
    // BWAMEM2_INDEX uses dynamic memory (280 MB × genome_size_in_10MB_units).
    // For the synthetic test FASTA (50 kb) that resolves to a trivially small
    // value; cap it here so the test profile doesn't exceed the local machine.
    withLabel: process_high_memory {
        cpus   = 2
        memory = '4.GB'
        time   = '30.m'
    }
}

