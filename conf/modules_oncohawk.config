/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    oncohawk main workflow module configuration
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {

    withName: 'ONCOHAWK:CUTADAPT' {
        ext.args = { "-a ${params.adapter_r1} -A ${params.adapter_r2} --minimum-length 35" }
        publishDir = [
            path: { "${params.outdir}/qc/cutadapt" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                if (filename.endsWith('.cutadapt.log')) return filename
                return null
            }
        ]
    }

    withName: 'ONCOHAWK:BWAMEM2_MEM' {
        // Inject the per-lane @RG tag; -K 100000000 -Y follow BWA-MEM2 best practices
        ext.args  = { "-R '${meta.read_group}' -K 100000000 -Y" }
        // samtools sort output flags passed as args2 (sort_bam = true in workflow)
        ext.args2 = '-O BAM'
    }

    withName: 'ONCOHAWK:SAMTOOLS_MERGE' {
        publishDir = [
            path: { "${params.outdir}/alignment" },
            mode: params.publish_dir_mode,
            saveAs: { _filename -> null }
        ]
    }

    withName: 'ONCOHAWK:PICARD_MARKDUPLICATES' {
        // Use a distinct prefix to avoid Picard's input==output name collision check
        ext.prefix = { "${meta.id}.markdup" }
        ext.args   = '--CREATE_INDEX true --VALIDATION_STRINGENCY SILENT'
        publishDir = [
            path: { "${params.outdir}" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                if (filename.endsWith('.metrics.txt')) return "qc/picard/${filename}"
                if (filename.endsWith('.bam') || filename.endsWith('.bai')) return "alignment/${filename}"
                return null
            }
        ]
    }

}
