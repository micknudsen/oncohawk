/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    oncohawk HPC profile configuration
    Intended for SLURM-based HPC facilities.
    Adjust queue names and resource limits to match your cluster.
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {

    config_profile_name        = 'HPC profile'
    config_profile_description = 'Configuration for SLURM-based HPC execution'

    max_cpus   = 64
    max_memory = '256.GB'
    max_time   = '168.h'

    // Reference data — set these after running:
    //   nextflow run main.nf --workflow prepare_reference -profile hpc,singularity
    // ref_data_genome_fasta         = '/path/to/references/GCA_000001405.15_GRCh38_no_alt_analysis_set.fna'
    // ref_data_genome_bwamem2_index = '/path/to/references'

}


process {

    executor       = 'slurm'
    queue          = 'normal'       // Adjust to your cluster queue name
    clusterOptions = ''             // Add any cluster-specific options here (e.g. --account)

    withLabel: process_single {
        cpus   = 1
        memory = '4.GB'
        time   = '2.h'
    }
    withLabel: process_low {
        cpus   = 4
        memory = '16.GB'
        time   = '4.h'
    }
    withLabel: process_medium {
        cpus   = 8
        memory = '32.GB'
        time   = '8.h'
    }
    withLabel: process_high {
        cpus   = 16
        memory = '64.GB'
        time   = '24.h'
    }
    withLabel: process_long {
        time   = '72.h'
    }
    withLabel: process_high_memory {
        memory = '128.GB'
    }

}

executor {
    $slurm {
        queueSize    = 200
        pollInterval = '30 sec'
    }
}
