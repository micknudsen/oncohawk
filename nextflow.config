/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    oncohawk Nextflow config file
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {

    // Workflow selection
    workflow                   = 'oncohawk'

    // Input / output
    input                      = null
    outdir                     = 'results'
    publish_dir_mode           = 'copy'

    // Reference data — set in a profile config (e.g. conf/hpc.config)
    // after running `nextflow run main.nf --workflow prepare_reference` once.
    ref_data_genome_fasta           = null  // Path to the uncompressed reference FASTA
    ref_data_genome_bwamem2_index   = null  // Path to the directory containing the bwa-mem2 index
    ref_data_genome_gtf             = null  // Path to the GENCODE GTF

    // PREPARE_REFERENCE parameters (used only when running --workflow prepare_reference)
    reference_dir              = 'references'
    genome_url                 = 'https://ftp.ncbi.nlm.nih.gov/genomes/all/GCA/000/001/405/GCA_000001405.15_GRCh38/seqs_for_alignment_pipelines.ucsc_ids/GCA_000001405.15_GRCh38_no_alt_analysis_set.fna.gz'
    gencode_gtf_url            = 'https://ftp.ebi.ac.uk/pub/databases/gencode/Gencode_human/release_50/gencode.v50.basic.annotation.gtf.gz'

    // Adapter trimming (TruSeq R1/R2 by default)
    adapter_r1                 = 'AGATCGGAAGAGCACACGTCTGAACTCCAGTCA'
    adapter_r2                 = 'AGATCGGAAGAGCGTCGTGTAGGGAAAGAGTGT'

    // Boilerplate
    help                       = false
    version                    = false

}

// Load base resource configuration
includeConfig 'conf/base.config'

// Load module-level publishDir and resource overrides
includeConfig 'conf/modules.config'

// Profiles
profiles {

    // ── Container runtimes ──────────────────────────────────────────────────
    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        singularity.enabled    = false
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
    }

    // ── Execution environments ───────────────────────────────────────────────
    hpc {
        includeConfig 'conf/hpc.config'
    }

    // ── Debug ────────────────────────────────────────────────────────────────
    debug {
        dumpHashes              = true
        process.beforeScript    = 'echo $HOSTNAME'
        cleanup                 = false
        nextflow.enable.configProcessNamesValidation = true
    }

}

// Disable noisy unmatched selector warnings in normal runs.
// Keep strict selector validation available via -profile debug.
nextflow.enable.configProcessNamesValidation = false

// Shell settings for all processes
process.shell = ['/bin/bash', '-euo', 'pipefail']

// Reporting
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_report.html"
    overwrite = true
}

trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_trace.txt"
    overwrite = true
}

dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/pipeline_dag.html"
    overwrite = true
}

// Pipeline manifest
manifest {
    name            = 'oncohawk'
    author          = 'Michael Knudsen'
    description     = 'Nextflow-based pipeline for tumor-only inference of somatic variation in myeloid malignancies'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=24.04.0'
    version         = '0.1.0'
}
